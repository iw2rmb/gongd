<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>local.gongd</string>

    <key>ProgramArguments</key>
    <array>
      <string>gongd</string>
      <string>--socket</string>
      <string>/tmp/gongd.sock</string>
      <string>--control-socket</string>
      <string>/tmp/gongd.ctl.sock</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/gongd.out.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/gongd.err.log</string>
  </dict>
</plist>
