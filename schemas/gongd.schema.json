{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/gongd.schema.json",
  "title": "gongd event stream message",
  "description": "One newline-delimited JSON event emitted by gongd.",
  "oneOf": [
    {
      "title": "worktree event",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "folder": {
          "type": "string",
          "description": "Absolute path to the watched folder root.",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "file_created",
            "file_modified",
            "file_deleted",
            "file_renamed",
            "dir_created",
            "dir_modified",
            "dir_deleted",
            "dir_renamed"
          ]
        },
        "path": {
          "type": "string",
          "description": "Path relative to the folder root. Rename events use the current 'from -> to' string payload.",
          "minLength": 1
        },
        "git_path": {
          "type": "null",
          "description": "Always null for worktree events."
        },
        "ts_unix_ms": {
          "type": "integer",
          "description": "Unix timestamp in milliseconds.",
          "minimum": 0
        }
      },
      "required": [
        "folder",
        "type",
        "path",
        "git_path",
        "ts_unix_ms"
      ]
    },
    {
      "title": "git metadata event",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "folder": {
          "type": "string",
          "description": "Absolute path to the watched folder root.",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "git_head_changed",
            "git_index_changed",
            "git_refs_changed",
            "git_packed_refs_changed",
            "git_changed"
          ]
        },
        "path": {
          "type": "null",
          "description": "Always null for .git events."
        },
        "git_path": {
          "type": "string",
          "description": "Path relative to the folder .git directory.",
          "minLength": 1
        },
        "ts_unix_ms": {
          "type": "integer",
          "description": "Unix timestamp in milliseconds.",
          "minimum": 0
        }
      },
      "required": [
        "folder",
        "type",
        "path",
        "git_path",
        "ts_unix_ms"
      ]
    }
  ]
}
